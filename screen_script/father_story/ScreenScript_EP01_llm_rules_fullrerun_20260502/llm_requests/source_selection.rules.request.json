        "text": "音乐提示：大提琴缓缓拉响，低沉而微颤",
        "scene_name": "医院VIP候诊区·日",
        "speaker": "",
        "line_start": 155,
        "line_end": 155,
        "metadata": {
          "shot_type": "",
          "performance": ""
        }
      },
      {
        "unit_id": "U0070",
        "index": 70,
        "source_type": "screen",
