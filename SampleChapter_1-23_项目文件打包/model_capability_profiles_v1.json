{
  "profiles_id": "samplechapter_model_capability_profiles_v1",
  "version": "1.0.0-draft",
  "status": "spec_only",
  "purpose": "Model-agnostic capability registry for prompt rendering and payload generation.",
  "notes": [
    "This file does not change runtime behavior.",
    "Capabilities should be verified against each provider's latest API docs before production use."
  ],
  "capability_dimensions": {
    "supports_negative_prompt": "Whether API has dedicated negative prompt field.",
    "supports_audio_generation": "Whether API can generate synchronized audio.",
    "duration_min_sec": "Minimum supported output duration.",
    "duration_max_sec": "Maximum supported output duration.",
    "supported_resolutions": "Allowed resolution values.",
    "supported_ratios": "Allowed aspect ratios.",
    "supports_last_frame_return": "Whether API can return last frame image.",
    "supports_web_search": "Whether API can use web search augmentation."
  },
  "rendering_policies": {
    "when_negative_supported": {
      "strategy": "Split intent into prompt + negative_prompt",
      "mapping": {
        "must": "prompt",
        "prefer": "prompt",
        "avoid": "negative_prompt",
        "dialogue": "prompt",
        "continuity": "prompt"
      }
    },
    "when_negative_not_supported": {
      "strategy": "Convert avoid-list into positive constraints and hard limits",
      "mapping": {
        "must": "prompt",
        "prefer": "prompt",
        "avoid": "prompt_as_constraints",
        "dialogue": "prompt",
        "continuity": "prompt"
      },
      "risk_flags": [
        "avoid_constraints_may_be_weaker",
        "needs_stronger_qa_after_generation"
      ]
    }
  },
