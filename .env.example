ATLASCLOUD_API_KEY=your_atlas_cloud_api_key_here
NOVITA_API_KEY=your_novita_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Global image generation/edit provider selector.
# Supported: openai, atlas-openai, grok
IMAGE_MODEL=openai

# Global image-to-video provider selector.
# Supported: atlas-seedance1.5, novita-seedance1.5
VIDEO_MODEL=atlas-seedance1.5
