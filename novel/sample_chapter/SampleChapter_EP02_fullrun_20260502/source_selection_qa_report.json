    },
    {
      "severity": "medium",
      "issue": "critical_unit_omitted",
      "unit_id": "U1039",
      "text": "影儿低声报告匈奴营地坐标时，密室外忽然传来铁牛急促敲"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1042",
      "text": "次日黎明，边塞草原上寒风如刀，刺骨卷起草叶碎屑，空气"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1043",
      "text": "中弥漫着露水湿冷的土腥味和远方马粪隐隐臭气。林辰策马"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1044",
      "text": "在前，战袍粗布裹紧精壮身段，腰间火药包沉甸甸压得马鞍"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1045",
      "text": "吱呀，铜钱袋摩擦出细碎金属响。他腹黑眼神扫视灰蒙蒙天"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1046",
      "text": "际，野心膨胀得正欢——昨夜影儿那情报，老子直接试火"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1047",
      "text": "药，灭了这小股匈奴斥候，顺带压实她忠诚，武力网再锁一"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1048",
      "text": "环，三年内边塞首富加战神，爽感如火燎。就这点小麻烦，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1049",
      "text": "还想挡老子？身后影儿劲装裹身，冷峻身影紧随马匹，颈侧"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1050",
      "text": "刀疤在微光中隐现银线，她呼吸微促间眼神闪过娇羞顺从，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1051",
      "text": "昨夜密室耻辱转为对林辰武力碾压的依恋渴望，急于证明价"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1052",
      "text": "值换取归属。铁牛魁梧身躯骑马笨重，肌肉虬结拉扯布料，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1053",
      "text": "他直率低吼：“主子，牛砸他们！”兰姬异域胡服轻扬，丰满"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1054",
      "text": "曲线在马背颠簸中微颤，眼波流转紧握林辰袖口，热情依恋"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1055",
      "text": "中藏对影儿竞争的微妙嫉妒，低语情报：“营地东侧，二十"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1056",
      "text": "骑，坐标准了，林郎。”"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1057",
      "text": "林辰哼笑点头，现代知识降维打击一闪，指挥铁牛和影儿潜"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1058",
      "text": "入外围："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1059",
      "text": "“牛，冲散哨兵；影儿，刀法辅助，别莽。”铁牛应"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1060",
      "text": "声跃下，粗犷脚步踩碎草丛闷响，魁梧臂膀抡起铁棍砸向第"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1061",
      "text": "一个匈奴哨兵，骨头断裂的钝响混杂惨叫，热血喷溅腥甜味"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1062",
      "text": "扑鼻。影儿刀光如风掠过，劲装下身段紧绷，她侧身闪避箭"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1063",
      "text": "矢啸响，反手划开第二人皮毛战袍，血肉撕裂的黏腻触感渗"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1064",
      "text": "上手柄，颈侧旧刀疤拉扯出细汗咸涩，她微表情红晕一闪"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1065",
      "text": "——林辰指挥近在眼前，这汉人武力护短，让她从刺客冷酷"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1066",
      "text": "转为娇羞守护。林辰内心护短本能闪回昨夜蒙眼丝绸的凉"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1067",
      "text": "滑，强化两人从敌对到依恋的转折，他低沉："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1068",
      "text": "“干得不错，影"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1069",
      "text": "儿，老子护着你。”她喉头一梗，眼神顺从加深，劲装摩擦草"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1070",
      "text": "叶细碎声中协作默契初现。兰姬马匹辅助，异域马鞭甩出啪"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1071",
      "text": "响，驱散外围马群，汗臭和马粪味更浓，她眼波流转贴近林"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1072",
      "text": "辰：“林郎，情报稳了。”嫉妒张力隐现，却被热情依恋覆"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1073",
      "text": "盖。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1074",
      "text": "核心冲突骤起，匈奴斥候残暴反扑，马蹄践踏草地轰鸣如"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1075",
      "text": "雷，皮毛战袍裹紧他们粗野身段，弯刀挥舞间寒光逼人，空"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1076",
      "text": "气中汗臭腥味炸开。领头斥候咆哮：“汉狗，杀！”箭雨啸响"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1077",
      "text": "射来，林辰侧身闪避，战袍拉扯出细碎声，他点燃火药包，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1078",
      "text": "火折子一闪，轰隆巨响震颤大地，爆炸热浪如火龙席卷营"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1079",
      "text": "地，硝烟腻意瞬间吞没视野，火光映照血肉横飞的混乱——"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1080",
      "text": "帐篷焚烧噼啪，匈奴马匹嘶鸣倒地，灼热碎片划过林辰战袍"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1081",
      "text": "留下焦痕，皮肤刺痛中混杂硫磺焦臭。铁牛莽撞失位，被马"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1082",
      "text": "蹄逼退，他低吼挥棍却砸空，魁梧身躯险翻。兰姬马匹急"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1083",
      "text": "转，异域鞭子缠上铁牛腰带拉扯，丝滑触感救他一命，她眼"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1084",
      "text": "波微闪竞争警惕："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1085",
      "text": "“牛哥，稳着！”林辰风吹乱发，毒舌凡尔"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1086",
      "text": "赛大笑：“就这点战斗力？老子大学军训都比你们猛，下一个"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1087",
      "text": "谁来！”火药从工地发明直击战场杀器，降维威力爆棚，匈奴"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1088",
      "text": "斥候尸横遍野，热血喷溅的腥甜味和硝烟混杂草原寒风，爽"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1089",
      "text": "点如机关枪——灭小股，就这？野心直指呼衍单于王庭。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1090",
      "text": "战斗尾声，林辰亲手擒获一名漏网斥候，现代格斗融合军体"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1091",
      "text": "拳，反手锁喉钝响压地，粗粝掌心刮过他皮毛战袍黏腻，斥"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1092",
      "text": "候喉头滚动，汗臭味扑鼻："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1093",
      "text": "“说，大军坐标！”影儿冷峻守护"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1094",
      "text": "在旁，劲装紧裹身段，她刀尖抵住斥候颈侧，微表情红晕暴"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1095",
      "text": "露对林辰近身指挥的娇羞顺从，心理从规训耻辱转为情感融"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1096",
      "text": "合渴望。铁牛喘息感恩呼喊：“主子威武，牛服！”魁梧臂膀"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1097",
      "text": "拍地闷响，忠心耿耿中对影儿竞争警惕稍缓。兰姬下马贴"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1098",
      "text": "近，胡服微滑露出肩头细腻，热情低语：“林郎，灭了他们，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1099",
      "text": "边塞情报网稳。”林辰哼笑起身，战袍焦痕拉扯细碎，内心轻"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1100",
      "text": "蔑古人野蛮一闪，护短网覆盖众女："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1101",
      "text": "“丫头们，老子灭匈奴，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1102",
      "text": "你们情报功劳大。”营地化为焦土，战功初显，铜钱袋中赏金"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1103",
      "text": "预感沉甸甸，阿翠远程书信昨夜已到，温柔笔迹隐现守护："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1104",
      "text": "“辰哥，边塞小心，丫头等着。”家庭锚点加深，刘婉政治助"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1105",
      "text": "力通过情报网隐现——公主手帕余温犹在，朝堂支持锁死。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1106",
      "text": "草原硝烟尚未散尽，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1107",
      "text": "一骑斥候仓皇逃脱，身后尘土飞扬中传"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1108",
      "text": "来低沉的号角声，预示呼衍单于大举入侵的阴影逼近。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1109",
      "text": "## 16. 后宫争宠与财富垄断"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1110",
      "text": "林氏庄园温泉池，傍晚余晖斜洒，热气如雾缭绕石壁，硫磺"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1111",
      "text": "味混杂着野花隐隐清香，池水温润荡漾，映出丝绸浴袍下曲"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1112",
      "text": "线隐约的轮廓。林辰推开竹门而入，战袍上硝烟余味刺鼻，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1113",
      "text": "焦痕拉扯出细碎布料声，他精壮身段微显疲惫，却眼神腹黑"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1114",
      "text": "一扫，野心膨胀得正欢——边塞那小股匈奴灭了，火药一炸"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1115",
      "text": "就这？影儿情报稳，后宫丫头们等着老子规训，顺带踩李老"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1116",
      "text": "头权谋，财富网再锁一环，三年内大汉首富加战神，爽感如"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1117",
      "text": "火燎。身后铁牛魁梧身影守门，肌肉虬结拉扯粗布，他直率"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1118",
      "text": "低吼：“主子，牛守着，谁来牛砸！”脚步闷响回荡外廊，忠"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1119",
      "text": "心耿耿护短网锁死。林辰哼笑甩掉战袍，铜钱袋沉甸甸落地"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1120",
      "text": "叮当，浸入池中温水包裹肌肉酸痛，热浪直冲脑门，瞬间洗"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1121",
      "text": "去草原寒风的刺骨。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1122",
      "text": "阿翠布衣素裹的温柔身影先迎上，丝绸浴袍轻贴肌肤，她红"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1123",
      "text": "脸低头递上热巾，眼神隐忍坚强中藏守护依恋："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1124",
      "text": "“郎君，边塞"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1125",
      "text": "辛苦，丫头擦拭。”林辰接过，粗粝指腹刮过她腰线细腻，黏"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1126",
      "text": "腻触感拉扯出她呼吸急促的细颤，心理压迫如仪式般升温"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1127",
      "text": "——这丫头，从贫苦守护到现在后宫锚点，老子护着你，谁"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1128",
      "text": "敢动？阿翠喉头一梗，隐忍嫉妒后宫扩张一闪，却以贤惠动"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1129",
      "text": "作擦拭他臂上刀疤，温热巾布渗入皮肤咸涩："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1130",
      "text": "“小心身子，丫"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1131",
      "text": "头等着你安稳。”林辰毒舌凡尔赛低笑：“就这点硝烟味儿？"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1132",
      "text": "老子大学军训都比边塞猛，下次带你去瞧瞧。”她红晕加深，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1133",
      "text": "浴袍边缘微颤，家庭张力稳固，情感从青梅守护递进到隐忍"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1134",
      "text": "争宠。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1135",
      "text": "苏清儿从池边悄然现身，绸缎罗裙换成薄丝浴袍，腹黑眼波"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1136",
      "text": "流转递上葡萄酒，果香醇厚炸开舌尖，她动机商业天才般稳"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1137",
      "text": "后宅平衡：“林郎，边塞战功，酒业网已垄断，铜钱堆成山，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1138",
      "text": "叮当声昨夜就震庄园。”林辰端起玉杯，酒液凉滑入喉，混杂"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1139",
      "text": "温泉硫磺的独特腻意，他先喂她一口，粗粝掌心压住杯沿，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1140",
      "text": "视觉上金液顺唇角滑落："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1141",
      "text": "“边塞硝烟盖不住你的绸缎香，就这"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1142",
      "text": "点算计？老子盐铁策一出，你这首富位子稳了。”苏清儿腹黑"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1143",
      "text": "一笑，眼神微闪对兰姬异域竞争的隐秘不满，却喉头滚动顺"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1144",
      "text": "从，浴袍下曲线微颤，触感黏腻中生出智力互补的渴望："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1145",
      "text": "“郎"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1146",
      "text": "君威武，资金援助随叫随到。”财富暴增爽点爆棚，铜钱堆积"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1147",
      "text": "的物质冲击如金锭反光刺眼，源于林辰现代经商开挂的因果"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1148",
      "text": "延伸，她短暂恐惧被视为工具一闪，林辰凡尔赛回应化解："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1149",
      "text": "“你的脑子配得上这池热汤，丫头们听着，老子的人，谁敢小"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1150",
      "text": "瞧？”"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1151",
      "text": "兰姬异域胡服化作丝绸浴袍，丰满身段在蒸汽中微颤，她热"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1152",
      "text": "情奔放上前，舞步轻溅水花啪响，眼波流转紧握林辰袖口残"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1153",
      "text": "留的战袍布角：“林郎，情报功劳大，边塞归属稳了。”动机"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1154",
      "text": "追逐征服欲，她低语分享匈奴余党坐标，汗珠顺锁骨滑落咸"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1155",
      "text": "涩味渗空气，半公开观看压迫升温——后宫丫头们眼神微"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1156",
      "text": "变，她却贴近制造身体张力，胡服解带般的暧昧拉丝。林辰"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1157",
      "text": "哼笑喂她酒，果香混杂她体香腻意："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1158",
      "text": "“舞姿不错，下次绣个二"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1159",
      "text": "维码，老子扫码领红包。”兰姬红晕娇媚，依恋加深，却隐现"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1160",
      "text": "对影儿武力竞争的嫉妒张力，浴袍边缘滑落肩头细腻，心理"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1161",
      "text": "从新鲜欲火转为床上助兴的顺从。刘婉高贵身影倚池壁，宫"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1162",
      "text": "装换丝绸浴袍，凤眸傲气毕现，她微皱眉推开兰姬手势，骄"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1163",
      "text": "傲外冷内热试探："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1164",
      "text": "“林辰，赐婚后宫，你这凡尔赛劲儿，朝堂"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1165",
      "text": "盐铁策可别耽搁。”林辰侧身喂酒，凉滑杯沿触她唇，仪式般"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1166",
      "text": "缠指刘婉绣金手帕余温："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1167",
      "text": "“公主殿下，就这点政治压力？老子"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1168",
      "text": "灭匈奴，你专宠稳了。”她喉头一梗，柔情依附闪现，浴袍下"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1169",
      "text": "呼吸急促，政治情感从外冷递进到争宠柔情，眼神钩子拉紧"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1170",
      "text": "林辰野心。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1171",
      "text": "影儿冷峻劲装换浴袍，颈侧刀疤在蒸汽中隐现银线，她紧握"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1172",
      "text": "袍边顺从注视林辰，动机从刺杀耻辱转为娇羞忠诚，急于证"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1173",
      "text": "明价值：“主子，边塞情报更新，李丞相内乱……”话音未"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1174",
      "text": "落，刘婉傲娇眼神扫来，争宠冲突渐起——兰姬舞步轻挡，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1175",
      "text": "苏清儿腹黑微笑旁观，阿翠隐忍递巾缓和。林辰护短本能一"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1176",
      "text": "闪，腹黑主导起身，水花溅起闷响，他依次拍她们肩头，粗"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1177",
      "text": "粝掌心拉扯浴袍细缝，规训压迫如场域般笼罩："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1178",
      "text": "“丫头们，老"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1179",
      "text": "子后宫，谁敢争？情报吐干净，财富分你们一半。”影儿微颤"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1180",
      "text": "身段，眼神顺从加深，劲装旧忆中生出情感融合渴望；兰姬"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1181",
      "text": "热情低头，嫉妒转为依恋；刘婉柔情微露，政治助力锁死；"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1182",
      "text": "苏清儿腹黑一笑，商业互补稳固；阿翠温柔守护，家庭锚点"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1183",
      "text": "深化。后宫从隐忍争宠转为林辰主导的顺从，仪式喂酒的黏"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1184",
      "text": "腻触感和低语笑声中，野心膨胀——金锭堆得再高，也填不"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1185",
      "text": "满那瞬息空虚，不过无所谓，老子明天再印一批。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1186",
      "text": "苏清儿汇报尾声，铜钱叮当声从外堂隐约传来，财富垄断雏"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1187",
      "text": "形初现，推动林辰从武力爆发向权谋巅峰弧线。影儿低声续"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1188",
      "text": "报：“李丞相嫉恨战功，保守派反扑，朝堂有变。”林辰眼神"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1189",
      "text": "骤冷，现代智商轻蔑古人权谋一闪，果断回应："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1190",
      "text": "“就这点阴"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1191",
      "text": "谋？老子策论一出，他跪着接。”阿翠递上热巾的温柔举动，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1192",
      "text": "进一步稳定动态，避免争宠升级。众人沉浸葡萄酒余韵，果"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1193",
      "text": "香腻意中笑声低回，温泉热气包裹身心张力。"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1194",
      "text": "正当林辰喂完最后一口酒，池边竹门微颤，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1195",
      "text": "一封从长安急驰"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1196",
      "text": "而至的密信滑入，信封上李丞相印玺墨香刺鼻，展开瞬间，"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1197",
      "text": "阴鸷笔迹跃然纸上："
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1198",
      "text": "“速回朝堂，盐铁策有变。”门外铁牛急"
    },
    {
      "severity": "info",
      "issue": "source_unit_not_selected_or_omitted",
      "unit_id": "U1199",
      "text": "促脚步声逼近，温泉热气中林辰眼神骤冷。"
    }
  ],
