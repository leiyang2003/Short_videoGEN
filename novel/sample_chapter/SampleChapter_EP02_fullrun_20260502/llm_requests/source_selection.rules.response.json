        "message": {
          "role": "assistant",
          "content": "{\"selected_shots\":[{\"shot_id\":\"SH01\",\"source_unit_ids\":[\"U0070\",\"U0071\",\"U0072\",\"U0073\"],\"source_range\":[71,74],\"summary\":\"晨光中，林辰准备粗盐和肥皂，阿翠跟在身后，两人走向集市。\",\"scene_name\":\"2. 集市初试现代知识\",\"story_function\":\"开场setup，引入发明产品和人物关系，建立逆袭起点。\",\"selection_reason\":\"关键剧情beat：展示现代知识发明（粗盐、肥皂），人物互动（林辰自信，阿翠担忧），视觉可执行（晨光、产品准备）。\",\"merge_reason\":\"相邻units，同场/时间，动作目标一致（准备出发），无对话变化，视觉兼容（行走场景）。\",\"keyframe_moment\":\"林辰抖开破布袋，粗盐粒在陶罐里叮当作响，阿翠提着小木盒跟在身后。\",\"must_include_evidence\":[],\"dialogue_policy\":\"无对话\",\"key_props\":[\"陶罐粗盐\",\"小木盒肥皂块\"],\"i2v_risk_notes\":[\"确保晨光效果自然，避免产品细节模糊\"],\"omitted_unit_ids\":[],\"is_montage\":false},{\"shot_id\":\"SH02\",\"source_unit_ids\":[\"U0074\",\"U0075\",\"U0076\"],\"source_range\":[75,77],\"summary\":\"阿翠低声询问肥皂能否卖钱，林辰自信调侃古人洗衣方式。\",\"scene_name\":\"2. 集市初试现代知识\",\"story_function\":\"深化人物关系，林辰毒舌自信，阿翠隐忍担忧，预示集市挑战。\",\"selection_reason\":\"关键对白和情绪节点：阿翠担忧，林辰调侃，视觉可执行（行走对话）。\",\"merge_reason\":\"同一说话人连续，阿翠单句询问紧接林辰回应，无动作变化，keyframe单一瞬间。\",\"keyframe_moment\":\"阿翠低声问辰哥这东西真能卖钱，林辰瞥她一眼嘴角勾起。\",\"must_include_evidence\":[],\"dialogue_policy\":\"阿翠询问，林辰回应\",\"key_props\":[\"小木盒肥皂\"],\"i2v_risk_notes\":[\"单一speaker：林辰主导回应，阿翠仅背景可见\"],\"omitted_unit_ids\":[],\"is_montage\":false},{\"shot_id\":\"SH03\",\"source_unit_ids\":[\"U0077\"],\"source_range\":[78,78],\"summary\":\"阿翠卷起袖子帮林辰铺摊，眼神担忧。\",\"scene_name\":\"2. 集市初试现代知识\",\"story_function\":\"过渡到集市，展示阿翠忠诚支持。\",\"selection_reason\":\"关键动作：铺摊setup，情绪转折（担忧到行动）。\",\"merge_reason\":\"单unit，无对话，视觉独立（铺摊瞬间）。\",\"keyframe_moment\":\"阿翠卷起袖子帮他铺摊，眼神中藏着隐忍的担忧。\",\"must_include_evidence\":[],\"dialogue_policy\":\"无对话\",\"key_props\":[\"破席\",\"陶罐\",\"木盒\"],\"i2v_risk_notes\":[],\"omitted_unit_ids\":[],\"is_montage\":false},{\"shot_id\":\"SH04\",\"source_unit_ids\":[\"U0078\",\"U0079\",\"U0080\",\"U0081\"],\"source_range\":[79,82],\"summary\":\"林辰瞥阿翠一眼，调侃肥皂效果优于古人捶衣方式。\",\"scene_name\":\"2. 集市初试现代知识\",\"story_function\":\"强化林辰现代知识优势，幽默情绪节点。\",\"selection_reason\":\"关键对白：林辰连续调侃，视觉兼容（集市背景）